{
  "name": "@nbgstravel/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node start.cjs",
    "build": "node -e \"console.log('api build complete')\"",
    "lint": "node -e \"console.log('api lint placeholder')\"",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "restore:production": "node src/db/restore.js ../../deployment/production/database/production-database.sql",
    "setup:production": "npm run migrate && npm run restore:production"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.12.0",
    "nodemailer": "^6.10.0",
    "zod": "^3.24.2"
  }
}
